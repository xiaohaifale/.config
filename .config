# 1. 指定你的芯片架构 (MT7981/Filogic 820)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cudy_tr3000=y

# 2. 闪讯拨号核心插件 (必须)
CONFIG_PACKAGE_ppp-mod-pppoe-extra=y
CONFIG_PACKAGE_luci-app-netkeeper=y
CONFIG_PACKAGE_luci-proto-netkeeper=y

# 3. 之前咱们折腾的防护插件 (建议带上)
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_curl=y
